---
const reasons = [
  {
    num: "01",
    title: "Teknisi Berpengalaman",
    desc: "Tim teknisi tersertifikasi dengan pengalaman 8+ tahun menangani berbagai merek dan tipe alat rumah tangga.",
    icon: "users",
  },
  {
    num: "02",
    title: "Bergaransi Resmi",
    desc: "Setiap layanan diberikan garansi 1-3 bulan meliputi sparepart dan jasa teknisi. Tenang tanpa khawatir kerusakan ulang.",
    icon: "shield",
  },
  {
    num: "03",
    title: "Harga Transparan",
    desc: "Estimasi harga diberikan di awal sebelum pekerjaan dimulai. Tanpa biaya tersembunyi, tanpa kejutan di akhir.",
    icon: "money",
  },
  {
    num: "04",
    title: "Respon Cepat",
    desc: "Respon WhatsApp rata-rata 5 menit. Same-day service tersedia untuk panggilan sebelum jam 3 sore.",
    icon: "zap",
  },
  {
    num: "05",
    title: "Home Service Lengkap",
    desc: "Teknisi datang langsung ke lokasi Anda dengan peralatan lengkap. Tanpa perlu bongkar-muat alat ke bengkel.",
    icon: "home",
  },
  {
    num: "06",
    title: "Cakupan Area Luas",
    desc: "Melayani Bandung, Cimahi, Kabupaten Bandung, Bandung Barat, Sumedang, dan Jatinangor plus area sekitarnya.",
    icon: "map",
  },
];

const icons: Record<string, string> = {
  users: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  money: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  zap: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  home: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  map: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
};
---

<section class="why-us" id="keunggulan">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Kenapa Pilih Kami
      </span>
      <h2>Keunggulan Sejuk Service yang Dipercaya Pelanggan</h2>
      <p>Kami berkomitmen memberikan layanan service terbaik dengan standar profesional, transparansi harga, dan kepuasan pelanggan sebagai prioritas utama.</p>
    </div>

    <div class="why-grid">
      {
        reasons.map((r) => (
          <article class="why-card reveal">
            <span class="why-num">{r.num}</span>
            <div class="why-icon">
              <span set:html={icons[r.icon]} />
            </div>
            <h3>{r.title}</h3>
            <p>{r.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .why-us {
    background: var(--bg-soft);
  }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  .why-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 30px;
    transition: all 0.3s;
    position: relative;
  }
  .why-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary-light);
  }
  .why-num {
    position: absolute;
    top: 22px;
    right: 24px;
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--primary-light);
    line-height: 1;
    opacity: 0.7;
  }
  .why-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    background: var(--primary);
    color: white;
    display: grid;
    place-items: center;
    margin-bottom: 18px;
    box-shadow: var(--shadow-primary);
  }
  .why-icon :global(svg) {
    width: 24px;
    height: 24px;
  }
  .why-card h3 {
    margin-bottom: 10px;
    font-size: 1.15rem;
  }
  .why-card p {
    color: var(--text-muted);
    font-size: 14.5px;
  }
  @media (max-width: 1024px) {
    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .why-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
