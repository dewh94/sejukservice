---
import { testimonials } from "../data/testimonials";
---

<section class="testi" id="testimoni">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
        Testimoni Pelanggan
      </span>
      <h2>Apa Kata Pelanggan Setia Sejuk Service</h2>
      <p>Kepuasan pelanggan adalah prioritas utama kami. Berikut pengalaman nyata mereka menggunakan layanan Sejuk Service.</p>
    </div>

    <div class="testi-summary reveal">
      <div>
        <div class="rating-big">4.9</div>
        <div class="stars-big" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
        </div>
      </div>
      <div class="rating-text">
        Berdasarkan ulasan<br>pelanggan terverifikasi
      </div>
      <div class="divider"></div>
      <div class="platform">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        Google Reviews
      </div>
    </div>

    <div class="testi-grid">
      {
        testimonials.map((t) => (
          <article class="testi-card reveal">
            <div class="testi-quote-mark">"</div>
            <div class="testi-stars" aria-label="5 dari 5 bintang">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
            </div>
            <p class="testi-text">{t.text}</p>
            <div class="testi-author">
              <div class="testi-avatar" style={`background: ${t.avatarGradient}`}>{t.initials}</div>
              <div>
                <div class="testi-name">{t.name}</div>
                <div class="testi-meta">{t.location}</div>
                <span class="testi-service-tag">{t.service}</span>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .testi-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 50px;
    padding: 24px 32px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
    box-shadow: var(--shadow-sm);
  }
  .testi-summary .rating-big {
    font-size: 3rem;
    font-weight: 800;
    color: var(--text);
    line-height: 1;
  }
  .testi-summary .stars-big {
    display: flex;
    gap: 2px;
    color: var(--star);
  }
  .testi-summary .stars-big svg {
    width: 22px;
    height: 22px;
  }
  .testi-summary .rating-text {
    font-size: 14px;
    color: var(--text-muted);
  }
  .testi-summary .rating-text strong {
    color: var(--text);
  }
  .testi-summary .divider {
    width: 1px;
    height: 50px;
    background: var(--border);
  }
  .testi-summary .platform {
    font-weight: 700;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
  }
  .testi-summary .platform svg {
    width: 20px;
    height: 20px;
    color: var(--primary);
  }
  .testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  .testi-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 26px;
    transition: all 0.3s;
    position: relative;
  }
  .testi-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary-light);
  }
  .testi-quote-mark {
    position: absolute;
    top: 18px;
    right: 22px;
    font-size: 4rem;
    font-weight: 800;
    color: var(--primary-light);
    line-height: 1;
    font-family: serif;
  }
  .testi-stars {
    display: flex;
    gap: 2px;
    color: var(--star);
    margin-bottom: 14px;
  }
  .testi-stars svg {
    width: 16px;
    height: 16px;
  }
  .testi-text {
    color: var(--text);
    font-size: 14.5px;
    margin-bottom: 20px;
    line-height: 1.7;
    position: relative;
  }
  .testi-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .testi-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-weight: 800;
    color: white;
    font-size: 16px;
  }
  .testi-name {
    font-weight: 700;
    font-size: 14.5px;
  }
  .testi-meta {
    font-size: 12.5px;
    color: var(--text-soft);
  }
  .testi-service-tag {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 6px;
    background: var(--primary-light);
    color: var(--primary);
    font-size: 11px;
    font-weight: 700;
    margin-top: 4px;
  }
  @media (max-width: 1024px) {
    .testi-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .testi-grid {
      grid-template-columns: 1fr;
    }
    .testi-summary {
      padding: 20px;
      gap: 16px;
    }
    .testi-summary .divider {
      display: none;
    }
  }
</style>
