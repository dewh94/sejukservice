<section class="trust-bar">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-stat reveal">
        <div class="num" data-target="8">0<span class="suffix">+ Th</span></div>
        <div class="desc">Pengalaman Teknisi</div>
      </div>
      <div class="trust-stat reveal">
        <div class="num" data-target="60">0<span class="suffix"> Menit</span></div>
        <div class="desc">Rata-rata Waktu Response</div>
      </div>
      <div class="trust-stat reveal">
        <div class="num">7<span class="suffix"> Hari</span></div>
        <div class="desc">Buka Setiap Hari</div>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    background: linear-gradient(135deg, var(--navy) 0%, var(--primary) 100%);
    padding: 40px 0;
    color: white;
    position: relative;
    overflow: hidden;
  }
  .trust-bar::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 30px 30px;
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    position: relative;
  }
  .trust-stat {
    text-align: center;
    padding: 0 12px;
    border-right: 1px solid rgba(255, 255, 255, 0.15);
  }
  .trust-stat:last-child {
    border-right: none;
  }
  .trust-stat .num {
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 6px;
    letter-spacing: -0.02em;
  }
  .trust-stat .num .suffix {
    color: #93c5fd;
  }
  .trust-stat .desc {
    font-size: 13.5px;
    opacity: 0.85;
    font-weight: 500;
  }
  @media (max-width: 768px) {
    .trust-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    .trust-stat {
      border-right: 1px solid rgba(255, 255, 255, 0.15) !important;
      padding: 8px;
    }
    .trust-stat:last-child {
      border-right: none !important;
    }
    .trust-stat .num {
      font-size: 1.6rem;
    }
    .trust-stat .desc {
      font-size: 11px;
    }
  }
</style>
