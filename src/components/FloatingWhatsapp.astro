<style>
  .wa-float {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 90;
    display: flex;
    align-items: center;
    gap: 0;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border: 1px solid rgba(37, 211, 102, 0.3);
    border-radius: 100px;
    padding: 8px 8px 8px 12px;
    box-shadow: 0 12px 40px rgba(37, 211, 102, 0.3), 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }
  :global([data-theme="dark"]) .wa-float {
    background: rgba(30, 41, 59, 0.85);
    border-color: rgba(37, 211, 102, 0.4);
  }
  .wa-float:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 16px 50px rgba(37, 211, 102, 0.45);
  }
  .wa-float .wa-icon-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .wa-float .wa-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--whatsapp);
    display: grid;
    place-items: center;
    position: relative;
  }
  .wa-float .wa-icon svg {
    width: 26px;
    height: 26px;
    color: white;
  }
  .wa-float .wa-icon::before {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid var(--whatsapp);
    animation: pulse-wa 2.2s ease-out infinite;
  }
  .wa-float .wa-online {
    position: absolute;
    top: 0;
    right: 0;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--success);
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 1px var(--success);
  }
  .wa-float .wa-text {
    max-width: 0;
    opacity: 0;
    transition: max-width 0.35s ease, opacity 0.25s ease;
    white-space: nowrap;
    overflow: hidden;
  }
  .wa-float .wa-text-inner {
    padding-right: 12px;
  }
  .wa-float .wa-text .label {
    font-size: 11px;
    color: var(--text-soft);
    font-weight: 600;
    line-height: 1.2;
  }
  .wa-float .wa-text .title {
    font-size: 14px;
    color: var(--text);
    font-weight: 800;
    line-height: 1.2;
  }
  .wa-float:hover .wa-text {
    max-width: 200px;
    opacity: 1;
  }
  @media (min-width: 769px) {
    .wa-float .wa-text {
      max-width: 200px;
      opacity: 1;
    }
  }
  .mobile-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 88;
    display: none;
    gap: 10px;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid var(--border);
  }
  :global([data-theme="dark"]) .mobile-cta {
    background: rgba(15, 23, 42, 0.92);
  }
  .mobile-cta .btn {
    flex: 1;
    padding: 13px 16px;
    font-size: 14px;
  }
  .mobile-cta .btn svg {
    width: 16px;
    height: 16px;
  }
  @media (max-width: 768px) {
    .mobile-cta {
      display: flex;
    }
    .wa-float {
      bottom: 80px;
    }
    body {
      padding-bottom: 70px;
    }
    .wa-float .wa-text {
      display: none;
    }
    .wa-float {
      padding: 6px;
    }
    .wa-float .wa-icon {
      width: 54px;
      height: 54px;
    }
    .wa-float .wa-icon svg {
      width: 30px;
      height: 30px;
    }
  }
</style>
