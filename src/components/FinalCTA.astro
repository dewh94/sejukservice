---
const whatsapp = "https://wa.me/628122023364?text=Halo%20Sejuk%20Service,%20saya%20ingin%20konsultasi%20gratis%20sekarang";
const telephone = "tel:+628122023364";
---

<section class="final-cta">
  <div class="container">
    <div class="final-cta-inner reveal">
      <h2>Alat Rumah Tangga Bermasalah? Tim Teknisi Siap Datang Hari Ini</h2>
      <p>Jangan tunggu kerusakan makin parah. Konsultasi gratis via WhatsApp sekarang, dapatkan estimasi harga transparan, dan jadwalkan kunjungan teknisi sesuai waktu Anda.</p>
      <div class="final-cta-buttons">
        <a href={whatsapp} class="btn btn-lg" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Konsultasi Gratis Sekarang
        </a>
        <a href={telephone} class="btn btn-outline btn-lg">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Telepon Langsung
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    padding: 80px 0;
  }
  .final-cta-inner {
    background: linear-gradient(135deg, var(--navy) 0%, var(--primary) 100%);
    border-radius: var(--radius-xl);
    padding: 70px 60px;
    text-align: center;
    color: white;
    position: relative;
    overflow: hidden;
  }
  .final-cta-inner::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 30% 50%, rgba(255, 255, 255, 0.12) 1.5px, transparent 1.5px);
    background-size: 36px 36px;
    opacity: 0.6;
  }
  .final-cta-inner::after {
    content: "";
    position: absolute;
    top: -100px;
    right: -100px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(37, 211, 102, 0.25), transparent 70%);
    border-radius: 50%;
  }
  .final-cta-inner > * {
    position: relative;
    z-index: 1;
  }
  .final-cta h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin-bottom: 18px;
    color: white;
  }
  .final-cta p {
    font-size: 1.1rem;
    opacity: 0.92;
    max-width: 580px;
    margin: 0 auto 32px;
  }
  .final-cta-buttons {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .final-cta .btn-whatsapp {
    background: white;
    color: var(--navy);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }
  .final-cta .btn-whatsapp svg {
    color: var(--whatsapp);
  }
  .final-cta .btn-whatsapp:hover {
    background: var(--whatsapp);
    color: white;
    transform: translateY(-2px);
  }
  .final-cta .btn-whatsapp:hover svg {
    color: white;
  }
  .final-cta .btn-outline {
    color: white;
    border-color: rgba(255, 255, 255, 0.4);
  }
  .final-cta .btn-outline:hover {
    background: white;
    color: var(--navy);
    border-color: white;
  }
  @media (max-width: 768px) {
    .final-cta-inner {
      padding: 50px 24px;
    }
  }
</style>
