---
const whatsapp = "https://wa.me/6281222023364?text=Halo%20Sejuk%20Service,%20saya%20ingin%20konsultasi%20gratis";
const telephone = "tel:+6281222023364";
---

<section class="hero" id="beranda">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="container hero-inner">
    <div class="hero-content">
      <span class="hero-badge">
        <span class="dot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <span>Online sekarang • <strong>Respon 5 menit</strong></span>
      </span>

      <h1>
        Jasa Service Alat Rumah Tangga <span class="highlight gradient-text">Bandung</span> Profesional & Bergaransi
      </h1>

      <p class="hero-sub">
        Melayani service AC, cuci AC, service mesin cuci, water heater, dan pompa submersible di Bandung, Cimahi, Sumedang, Jatinangor, dan sekitarnya dengan teknisi berpengalaman dan harga transparan.
      </p>

      <div class="hero-cta">
        <a href={whatsapp} class="btn btn-whatsapp btn-lg" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Konsultasi Gratis
        </a>
        <a href={telephone} class="btn btn-outline btn-lg">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Hubungi via Telepon
        </a>
      </div>

      <div class="hero-trust">
        <div class="hero-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Bergaransi Resmi
        </div>
        <div class="hero-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Same-Day Service
        </div>
        <div class="hero-rating-mini">
          <span class="stars" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .587l3.668 7.568L24 9.75l-6 5.847 1.42 8.28L12 19.771l-7.42 4.106L6 15.597 0 9.75l8.332-1.595z"/></svg>
          </span>
          <strong>4.9/5</strong>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-image-wrap">
        <img src="/hero.png" alt="Teknisi Sejuk Service sedang melakukan perbaikan alat rumah tangga di rumah pelanggan Bandung" loading="eager" fetchpriority="high" width="800" height="1000" />
        <div class="hero-image-overlay">
          <div class="tech-name">Tim Teknisi Berpengalaman</div>
          <div class="tech-role">Pengalaman 8+ tahun • Home Service</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--header-h) + 60px);
    padding-bottom: 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }
  .hero-bg::before,
  .hero-bg::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }
  .hero-bg::before {
    width: 500px;
    height: 500px;
    background: var(--primary-glow);
    top: -150px;
    right: -100px;
    opacity: 0.6;
  }
  .hero-bg::after {
    width: 400px;
    height: 400px;
    background: rgba(37, 211, 102, 0.15);
    bottom: -100px;
    left: -100px;
  }
  .hero-grid {
    background-image: linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    position: absolute;
    inset: 0;
    z-index: -1;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    opacity: 0.5;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 60px;
    align-items: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px 8px 8px;
    border-radius: 100px;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    margin-bottom: 24px;
    font-size: 13.5px;
    font-weight: 600;
  }
  .hero-badge .dot {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--success);
    display: grid;
    place-items: center;
    position: relative;
  }
  .hero-badge .dot::before {
    content: "";
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 2px solid var(--success);
    animation: pulse 2s ease-out infinite;
  }
  .hero-badge .dot svg {
    width: 12px;
    height: 12px;
    color: white;
  }
  .hero-badge strong {
    color: var(--primary);
  }
  .hero h1 {
    margin-bottom: 22px;
  }
  .hero h1 .highlight {
    position: relative;
    display: inline-block;
  }
  .hero h1 .highlight::after {
    content: "";
    position: absolute;
    bottom: 6px;
    left: 0;
    right: 0;
    height: 14px;
    background: var(--primary-light);
    z-index: -1;
    border-radius: 4px;
  }
  .hero-sub {
    font-size: 1.12rem;
    color: var(--text-muted);
    max-width: 560px;
    margin-bottom: 32px;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 36px;
  }
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    align-items: center;
  }
  .hero-trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-muted);
  }
  .hero-trust-item svg {
    width: 20px;
    height: 20px;
    color: var(--success);
    flex-shrink: 0;
  }
  .hero-rating-mini {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero-rating-mini .stars {
    color: var(--star);
    display: flex;
    gap: 1px;
  }
  .hero-rating-mini .stars svg {
    width: 14px;
    height: 14px;
  }
  .hero-visual {
    position: relative;
  }
  .hero-image-wrap {
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    aspect-ratio: 4/5;
    box-shadow: var(--shadow-lg);
    background: linear-gradient(135deg, var(--primary-dark), var(--primary));
  }
  .hero-image-wrap::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(15, 23, 42, 0.7) 100%);
    z-index: 2;
  }
  .hero-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: luminosity;
    opacity: 0.9;
  }
  .hero-image-overlay {
    position: absolute;
    bottom: 24px;
    left: 24px;
    right: 24px;
    z-index: 3;
    color: white;
  }
  .hero-image-overlay .tech-name {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 2px;
  }
  .hero-image-overlay .tech-role {
    font-size: 13px;
    opacity: 0.85;
  }
  @media (max-width: 768px) {
    .hero {
      padding-top: calc(var(--header-h) + 30px);
      padding-bottom: 60px;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero-visual {
      max-width: 380px;
      margin: 0 auto;
    }
  }
  @media (max-width: 480px) {
    .hero-cta {
      display: none;
    }
    .hero-trust {
      gap: 16px;
    }
  }
</style>
