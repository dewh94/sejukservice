---
const whatsapp = "https://wa.me/6281222023364?text=Halo%20Sejuk%20Service,%20saya%20ingin%20konsultasi";
const telephone = "tel:+6281222023364";
---

<section class="contact" id="kontak">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Hubungi Kami
      </span>
      <h2>Konsultasi Gratis dengan Tim Sejuk Service</h2>
      <p>Hubungi kami sekarang untuk konsultasi gratis. Tim teknisi siap membantu menyelesaikan masalah alat rumah tangga Anda dengan respons cepat.</p>
    </div>

    <div class="contact-grid">
      <div class="contact-info">
        <a href={whatsapp} class="contact-card wa" target="_blank" rel="noopener" style="display:flex;">
          <div class="c-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <div class="c-label">WhatsApp</div>
            <div class="c-value">Klik untuk Chat</div>
            <div class="c-sub">Respon 5 menit • 24/7</div>
          </div>
        </a>

        <a href={telephone} class="contact-card phone">
          <div class="c-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <div class="c-label">Telepon Langsung</div>
            <div class="c-value">Klik untuk Menelepon</div>
            <div class="c-sub">Jam operasional 07.00 - 21.00</div>
          </div>
        </a>

        <div class="contact-card hours">
          <div class="c-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <div class="c-label">Jam Operasional</div>
            <div class="c-value">Senin - Minggu</div>
            <div class="c-sub">07.00 - 21.00 WIB (termasuk libur)</div>
          </div>
        </div>

        <div class="contact-card area">
          <div class="c-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="c-label">Cakupan Area</div>
            <div class="c-value">Bandung Raya & Sekitar</div>
            <div class="c-sub">Bandung, Cimahi, Kab. Bandung, Bandung Barat, Sumedang, Jatinangor</div>
          </div>
        </div>

        <a href={whatsapp + "%20gratis"} class="btn btn-whatsapp btn-lg btn-block" target="_blank" rel="noopener" style="margin-top: 8px;">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Chat Sekarang Juga
        </a>
      </div>

      <div class="contact-map reveal">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d506904.029!2d107.5731!3d-6.9034!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e68e6398252477f%3A0x146a1f93d3e815b2!2sBandung%2C%20West%20Java!5e0!3m2!1sen!2sid!4v1700000000000"
          loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Lokasi Sejuk Service di Bandung"></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .contact-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 22px;
    display: flex;
    gap: 16px;
    align-items: center;
    transition: all 0.3s;
  }
  .contact-card:hover {
    transform: translateX(4px);
    border-color: var(--primary);
    box-shadow: var(--shadow);
  }
  .contact-card .c-icon {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .contact-card .c-icon svg {
    width: 24px;
    height: 24px;
  }
  .contact-card.wa .c-icon {
    background: rgba(37, 211, 102, 0.15);
    color: var(--whatsapp);
  }
  .contact-card.phone .c-icon {
    background: var(--primary-light);
    color: var(--primary);
  }
  .contact-card.hours .c-icon {
    background: rgba(251, 191, 36, 0.15);
    color: var(--star);
  }
  .contact-card.area .c-icon {
    background: rgba(30, 58, 138, 0.12);
    color: var(--navy);
  }
  .contact-card .c-label {
    font-size: 12px;
    color: var(--text-soft);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .contact-card .c-value {
    font-size: 16px;
    font-weight: 700;
    margin-top: 2px;
  }
  .contact-card .c-sub {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 2px;
  }
  .contact-card.wa .c-value {
    color: var(--whatsapp-dark);
  }
  :global([data-theme="dark"]) .contact-card.wa .c-value {
    color: var(--whatsapp);
  }
  .contact-map {
    border-radius: var(--radius-md);
    overflow: hidden;
    min-height: 420px;
    box-shadow: var(--shadow-md);
    background: var(--surface-2);
    position: relative;
    border: 1px solid var(--border);
  }
  .contact-map iframe {
    width: 100%;
    height: 100%;
    min-height: 420px;
    border: 0;
    display: block;
  }
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
